<?xml version="1.0"?>
<phpunit xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
         bootstrap="bootstrap.php"
         colors="true"
         cacheResult="false">
    <testsuites>
        <testsuite name="unit">
            <directory suffix="Test.php">cases</directory>
        </testsuite>
    </testsuites>
</phpunit>
